# Supabase Postgres — use the Session pooler (port 5432) connection string.
# Settings → Database → Connect → "Direct" tab → "Session pooler".
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Public-facing keys (Settings → API). Safe to expose in browser code.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<eyJ... anon public key>

# Server-only secret (Settings → API → "Reveal"). Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=<eyJ... service_role secret>

# Required for production deployments where /api/refresh is publicly reachable.
# Generate with: openssl rand -hex 32
# cron-job.org sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=<random 64-hex-char string>

# Optional: override price band for the scraper (defaults: 28000 / 40000)
# SCRAPE_PRICE_MIN=28000
# SCRAPE_PRICE_MAX=40000
